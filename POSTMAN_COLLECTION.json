    {
      "name": "Get Request Logs - Last 20",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/api/lb/logs?limit=20",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "lb", "logs"],
          "query": [
            {
              "key": "limit",
              "value": "20"
            }
          ]
        },
        "description": "Get request history with IP and node routing information"
