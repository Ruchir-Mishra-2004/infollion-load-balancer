    {
      "name": "Get Metrics",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/api/lb/metrics",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "lb", "metrics"]
        },
        "description": "Get comprehensive load balancer metrics and statistics"
      }
