{
  "info": {
    "_postman_id": "lb-api-collection",
    "name": "Load Balancer API",
    "description": "Advanced Load Balancer with Consistent Hashing - API Testing Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Root - API Documentation",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000"
        },
        "description": "Get API documentation and available endpoints"
      }
    },
    {
      "name": "2. Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/health",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000"
        },
        "description": "Check if server is running"
      }
    },
    {
      "name": "Route - Single Request",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"ip\": \"192.168.1.100\"\n}"
        },
        "url": {
          "raw": "http://localhost:3000/api/lb/route",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "lb", "route"]
        },
        "description": "Route a request to a node based on IP address"
      }
    },
    {
      "name": "Route - Generate Random IP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "url": {
          "raw": "http://localhost:3000/api/lb/route",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "lb", "route"]
        },
        "description": "Route a request with randomly generated IP"
      }
    },
    {
      "name": "Simulate Traffic - 10 Requests",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/api/lb/simulate?count=10",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "lb", "simulate"],
          "query": [
            {
              "key": "count",
              "value": "10"
            }
          ]
        },
        "description": "Simulate 10 incoming requests with random IPs"
      }
    },
    {
      "name": "Simulate Traffic - 50 Requests",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/api/lb/simulate?count=50",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "lb", "simulate"],
          "query": [
            {
              "key": "count",
              "value": "50"
            }
          ]
        },
        "description": "Simulate 50 incoming requests"
      }
    },
    {
      "name": "Simulate Traffic - 100 Requests",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/api/lb/simulate?count=100",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "lb", "simulate"],
          "query": [
            {
              "key": "count",
              "value": "100"
            }
          ]
        },
        "description": "Simulate 100 incoming requests to see load distribution"
      }
